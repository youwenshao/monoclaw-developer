# Example operator environment for the opt-in vox phone bridge.
# Do not store real secrets in the release bundle.

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
VOX_PUBLIC_BASE_URL=https://example-tunnel.ngrok.app
VOX_LOG_DIR=~/.monoclaw/logs/vox

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Choose exactly one reviewed callback path:
# VOX_AGENT_URL=http://127.0.0.1:8765/query
# VOX_AGENT_CMD=/path/to/local-jsonl-agent-adapter
