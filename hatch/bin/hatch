  verify_model_pack_manifest "${HATCH_MODEL_PACK_ROOT}" | sed 's/^/  ok: /'
}

run_install_model() {
  local home_dir
  local model_rel
  local model_name
  local source_path
  local target_dir
  local target_path
  local tmp_path
  home_dir="$(monoclaw_home)"

  run_verify_model_pack
  model_rel="$(model_pack_manifest_field path)"
  model_name="$(basename "${model_rel}")"
  source_path="${HATCH_MODEL_PACK_ROOT}/${model_rel}"
  target_dir="${home_dir}/vendor/models/gemma-4-e4b"
  target_path="${target_dir}/${model_name}"
  tmp_path="${target_dir}/.${model_name}.tmp"

  log_step "model-pack" "Installing optional Gemma 4 E4B model"
  log_warn "LM Studio may copy this GGUF again during manual import; make sure the target Mac has enough free disk space"
  log_action mkdir -p "${target_dir}"
  log_action cp "${source_path}" "${tmp_path}"
  log_action mv "${tmp_path}" "${target_path}"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: Gemma 4 E4B model staged at %s\n' "${target_path}"
  else
    log_ok "Gemma 4 E4B model staged at ${target_path}"
  fi
  printf '  manual: import %s from LM Studio after first launch\n' "${target_path}"
}

run_verify_tools_pack() {
  log_step "tools-pack" "Checking optional Mona secretary tools pack"
  verify_tools_pack_manifest "${HATCH_TOOLS_PACK_ROOT}" | sed 's/^/  ok: /'
}

install_tools_pack_skills() {
  local source_dir="$1"
  local target_dir="$2"

  if [[ ! -d "${source_dir}" ]]; then
    log_warn "No Mona secretary skills staged at ${source_dir}"
    return
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: install Mona secretary skills into %s\n' "${target_dir}"
    return
  fi

  mkdir -p "${target_dir}"
  for skill_path in "${source_dir}"/*; do
    [[ -e "${skill_path}" ]] || continue
    local skill_name
    skill_name="$(basename "${skill_path}")"
    if [[ -e "${target_dir}/${skill_name}" ]]; then
      log_warn "Keeping existing skill ${target_dir}/${skill_name}"
      continue
    fi
    cp -R "${skill_path}" "${target_dir}/${skill_name}"
  done
  log_ok "Mona secretary skills installed into ${target_dir}"
}

install_tools_pack_plugins() {
  local source_dir="$1"
  local target_dir="$2"

  if [[ ! -d "${source_dir}" ]]; then
    log_warn "No Mona secretary plugins staged at ${source_dir}"
    return
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: install Mona secretary plugins into %s\n' "${target_dir}"
    return
  fi

  mkdir -p "${target_dir}"
  for plugin_path in "${source_dir}"/*; do
    [[ -e "${plugin_path}" ]] || continue
    local plugin_name
    plugin_name="$(basename "${plugin_path}")"
    if [[ -e "${target_dir}/${plugin_name}" ]]; then
      log_warn "Keeping existing plugin ${target_dir}/${plugin_name}"
      continue
    fi
    cp -R "${plugin_path}" "${target_dir}/${plugin_name}"
  done
  log_ok "Mona secretary plugins installed into ${target_dir}"
}

# Prefer MonoClaw-home interpreters (runtime venv, bundled vendor python), then
# the Hatch bundle staging python, then host python3. Must support `import yaml`.
hatch_python_with_yaml() {
  local home_dir="${1:-}"
  local candidate

  [[ -n "${home_dir}" ]] || return 1
  for candidate in \
    "${home_dir}/vendor/runtime/venv/bin/python" \
    "${home_dir}/vendor/python/current/bin/python3" \
    "${home_dir}/vendor/python/current/bin/python3.13" \
    "${home_dir}/vendor/python/current/bin/python3.12" \
    "${home_dir}/vendor/python/current/bin/python3.11"; do
    if [[ -x "${candidate}" ]] && "${candidate}" -c "import yaml" >/dev/null 2>&1; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  if candidate="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}" 2>/dev/null)"; then
    if [[ -n "${candidate}" && -x "${candidate}" ]] && "${candidate}" -c "import yaml" >/dev/null 2>&1; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  fi

  if have_command python3 && python3 -c "import yaml" >/dev/null 2>&1; then
    command -v python3
    return 0
  fi

  return 1
}

# True when config lists plugin_id under plugins.disabled (stdlib scan only).
mona_secretary_disabled_in_config() {
  local config_path="$1"
  local plugin_id="$2"

  python3 - "${config_path}" "${plugin_id}" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
plugin_id = sys.argv[2]

if not path.is_file():
    sys.exit(1)

lines = path.read_text(encoding="utf-8").splitlines()
in_plugins = False
in_disabled = False
disabled_col = None

for raw in lines:
    line = raw.split("#", 1)[0]
    if not line.strip():
        continue
    stripped = line.lstrip(" \t")
    indent = len(line) - len(stripped)
    if indent == 0:
        if stripped.startswith("plugins:"):
            in_plugins = True
            in_disabled = False
            disabled_col = None
        else:
            in_plugins = False
        continue
    if not in_plugins:
        continue
    if stripped.startswith("disabled:"):
        in_disabled = True
        disabled_col = indent
        continue
    if in_disabled and disabled_col is not None:
        if stripped.startswith("- "):
            item = stripped[2:].strip().strip("'\"")
            if item == plugin_id:
                sys.exit(0)
        elif indent <= disabled_col:
            in_disabled = False

sys.exit(1)
PY
}

# Opt the Hatch-shipped Mona secretary plugin into Runtime discovery by listing
# it in plugins.enabled. Does not merge example MCP or secretary YAML, and does
# not override plugins.disabled (warn + skip when the plugin is disabled).
seed_mona_secretary_plugins_enabled() {
  local home_dir="$1"
  local config_path="${home_dir}/config.yaml"
  local plugin_id="mona-secretary-tools"
  local python_bin

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: seed %s with plugins.enabled including %s (skipped if plugins.disabled lists it)\n' \
      "${config_path}" "${plugin_id}"
    return 0
  fi

  mkdir -p "${home_dir}"

  if [[ -f "${config_path}" ]] && mona_secretary_disabled_in_config "${config_path}" "${plugin_id}"; then
    log_warn "plugins.disabled lists ${plugin_id}; not adding to plugins.enabled (override manually if intended)"
    return 0
  fi

  if python_bin="$(hatch_python_with_yaml "${home_dir}")"; then
    local merge_out
    merge_out="$(mktemp "${TMPDIR:-/tmp}/hatch-mona-plugins.XXXXXX")"
    PYTHONDONTWRITEBYTECODE=1 "${python_bin}" - "${config_path}" "${plugin_id}" <<'PY' >"${merge_out}"
import sys
from pathlib import Path

import yaml  # type: ignore

config_path = Path(sys.argv[1])
plugin_id = sys.argv[2]

if config_path.exists():
    text = config_path.read_text(encoding="utf-8")
    try:
        data = yaml.safe_load(text) or {}
    except yaml.YAMLError:
        sys.stderr.write("invalid YAML in config\n")
        sys.exit(1)
else:
    data = {}

if not isinstance(data, dict):
    data = {}

plugins = data.get("plugins")
if not isinstance(plugins, dict):
    plugins = {}

disabled = plugins.get("disabled")
if isinstance(disabled, list) and plugin_id in disabled:
    print("disabled")
    sys.exit(0)

enabled = plugins.get("enabled")
if enabled is None:
    enabled_list: list = []
elif isinstance(enabled, list):
    enabled_list = list(enabled)
else:
    enabled_list = [enabled]

if plugin_id in enabled_list:
    print("noop")
    sys.exit(0)

enabled_list.append(plugin_id)
plugins["enabled"] = enabled_list
data["plugins"] = plugins

config_path.parent.mkdir(parents=True, exist_ok=True)
with config_path.open("w", encoding="utf-8") as handle:
    yaml.safe_dump(
        data,
        handle,
        sort_keys=False,
        default_flow_style=False,
        allow_unicode=True,
    )
print("merged")
PY
    py_status=$?
    merge_result="$(tr -d '\r\n' < "${merge_out}")"
    rm -f "${merge_out}"
    if [[ "${py_status}" -ne 0 ]]; then
      log_warn "Failed to merge ${config_path} for ${plugin_id} (python exit ${py_status})"
      return 0
    fi
    case "${merge_result}" in
      disabled)
        log_warn "plugins.disabled lists ${plugin_id}; not adding to plugins.enabled (override manually if intended)"
        ;;
      noop)
        log_ok "plugins.enabled already lists ${plugin_id}"
        ;;
      merged)
        log_ok "Updated ${config_path} with plugins.enabled including ${plugin_id}"
        ;;
      *)
        log_warn "Unexpected plugins.enabled seed result for ${config_path}: ${merge_result}"
        ;;
    esac
    return 0
  fi

  # No PyYAML: only safe to bootstrap an empty config without clobbering user YAML.
  if [[ -f "${config_path}" ]]; then
    log_warn "PyYAML is required to merge ${config_path}; add ${plugin_id} under plugins.enabled manually"
    return 0
  fi

  cat > "${config_path}" <<EOF
plugins:
  enabled:
    - ${plugin_id}
EOF
  log_ok "Created ${config_path} with plugins.enabled including ${plugin_id}"
}

run_install_tools() {
  local home_dir
  local target_dir
  home_dir="$(monoclaw_home)"
  target_dir="${home_dir}/vendor/mona-tools"

  run_verify_tools_pack
  log_step "tools-pack" "Installing optional Mona secretary tools"
  log_action rm -rf "${target_dir}"
  log_action mkdir -p "${home_dir}/vendor"
  log_action cp -R "${HATCH_TOOLS_PACK_ROOT}" "${target_dir}"
  install_tools_pack_skills "${HATCH_TOOLS_PACK_ROOT}/skills" "${home_dir}/skills"
  install_tools_pack_plugins "${HATCH_TOOLS_PACK_ROOT}/plugins" "${home_dir}/plugins"
  seed_mona_secretary_plugins_enabled "${home_dir}"
  printf '  manual: review %s before enabling host automation tools\n' "${target_dir}/docs/permissions.md"
  printf '  manual: copy MCP examples from %s only after reviewing path and permission scopes\n' "${target_dir}/config"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: Mona secretary tools installed at %s\n' "${target_dir}"
  else
    log_ok "Mona secretary tools installed at ${target_dir}"
  fi
}

run_verify_skill_deps() {
