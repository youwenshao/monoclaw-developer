}

run_verify_skill_readiness() {
  local home_dir
  home_dir="$(monoclaw_home)"

  log_step "skill-readiness" "Auditing installed skills against metadata.monoclaw.provisioning"

  local python_bin=""
  if [[ -x "${home_dir}/vendor/runtime/venv/bin/python3" ]]; then
    python_bin="${home_dir}/vendor/runtime/venv/bin/python3"
  elif python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}" 2>/dev/null)"; then
    :
  elif command -v python3 >/dev/null 2>&1; then
    python_bin="$(command -v python3)"
  else
    log_warn "No python3 available to parse SKILL.md frontmatter"
    return
  fi

  local exit_code=0
  PYTHONDONTWRITEBYTECODE=1 \
  MONOCLAW_HOME="${home_dir}" \
  HATCH_DRY_RUN="${HATCH_DRY_RUN}" \
  HATCH_SKILL_READINESS_FAIL_ON="${HATCH_SKILL_READINESS_FAIL_ON:-blocked_unknown}" \
    "${python_bin}" - <<'PY' || exit_code=$?
import os
import re
import sys
from pathlib import Path

HOME = Path(os.environ["MONOCLAW_HOME"])
EXCLUDED = {".git", ".github", ".hub", ".archive"}

POLICIES = {
    "stock_bundle_candidate",
    "provisioned_user_config_required",
    "external_runtime_only",
    "blocked_unknown",
}

LABELS = {
    "stock_bundle_candidate": "Ready",
    "provisioned_user_config_required": "Setup required",
    "external_runtime_only": "External runtime",
    "blocked_unknown": "Unclassified",
}


def extract_frontmatter(text: str) -> str:
    if not text.startswith("---"):
        return ""
    m = re.search(r"\n---\s*(?:\n|$)", text[3:])
    if not m:
        return ""
    return text[3 : m.start() + 3]


def _indent(line: str) -> int:
    return len(line) - len(line.lstrip(" "))


def find_provisioning_block(yaml_text: str) -> list[str] | None:
    """Locate the metadata.monoclaw.provisioning block lines.

    Avoids depending on PyYAML so this gate works under
    ``/usr/bin/python3`` on a freshly imaged Mac (the runtime venv with
    PyYAML may not exist yet at the moment ``verify-skill-readiness``
    is first invoked).
    """
    lines = yaml_text.splitlines()
    i = 0
    n = len(lines)
    while i < n:
        line = lines[i]
        if line.lstrip(" ").startswith("metadata:") and _indent(line) == 0:
            meta_indent = 0
            j = i + 1
            mc_indent = None
            while j < n:
                child = lines[j]
                if not child.strip():
                    j += 1
                    continue
                if _indent(child) <= meta_indent:
                    break
                if child.lstrip(" ").startswith("monoclaw:"):
                    mc_indent = _indent(child)
                    k = j + 1
                    prov_indent = None
                    while k < n:
                        prov_line = lines[k]
                        if not prov_line.strip():
                            k += 1
                            continue
                        if _indent(prov_line) <= mc_indent:
                            break
                        if prov_line.lstrip(" ").startswith("provisioning:"):
                            prov_indent = _indent(prov_line)
                            block_lines = []
                            m = k + 1
                            while m < n:
                                bl = lines[m]
                                if bl.strip() and _indent(bl) <= prov_indent:
                                    break
                                block_lines.append(bl)
                                m += 1
                            return block_lines
                        k += 1
                    return None
                j += 1
            return None
        i += 1
    return None


_BUNDLE_POLICY_RE = re.compile(r"^\s*bundle_policy:\s*([A-Za-z_][A-Za-z0-9_]*)")
_SYS_DEPS_HEADER_RE = re.compile(r"^(\s*)system_dependencies:\s*(.*)$")
_INLINE_LIST_RE = re.compile(r"\[([^\]]*)\]")
_LIST_ITEM_RE = re.compile(r"^\s*-\s+(.*)$")


def policy_from_block(block: list[str] | None) -> str:
    if not block:
        return "blocked_unknown"
    for line in block:
        m = _BUNDLE_POLICY_RE.match(line)
        if m:
            value = m.group(1).strip()
            return value if value in POLICIES else "blocked_unknown"
    return "blocked_unknown"


def _strip_quote(value: str) -> str:
    value = value.strip()
    if value.startswith(("'", '"')) and value.endswith(("'", '"')) and len(value) >= 2:
        return value[1:-1]
    return value


def system_deps_from_block(block: list[str] | None) -> list[str]:
    if not block:
        return []
    out: list[str] = []
    in_list = False
    list_indent = 0
    for line in block:
        header = _SYS_DEPS_HEADER_RE.match(line)
        if header:
            list_indent = len(header.group(1))
            inline = header.group(2).strip()
            inline_match = _INLINE_LIST_RE.match(inline)
            if inline_match:
                for raw in inline_match.group(1).split(","):
                    item = _strip_quote(raw.strip())
                    if item:
                        out.append(item)
                in_list = False
                continue
            in_list = True
            continue
        if in_list:
            if not line.strip():
                continue
            indent = _indent(line)
            if indent <= list_indent:
                in_list = False
                continue
            item_match = _LIST_ITEM_RE.match(line)
            if item_match:
                item = _strip_quote(item_match.group(1).strip())
                if item:
                    out.append(item)
    return out


def policy_for(yaml_text: str) -> str:
    return policy_from_block(find_provisioning_block(yaml_text))


def system_deps_for(yaml_text: str) -> list[str]:
    return system_deps_from_block(find_provisioning_block(yaml_text))


def find_dep_binary(name: str) -> Path | None:
    candidates = [
        HOME / "vendor" / "skill-deps" / "bin" / name,
        HOME / "vendor" / "mona-tools" / "bin" / name,
    ]
    for path in candidates:
        if path.is_file() and os.access(path, os.X_OK):
            return path
    return None


def walk_skills(root: Path):
    if not root.is_dir():
        return
    for skill_md in sorted(root.rglob("SKILL.md")):
        rel = skill_md.relative_to(root)
        if any(p in EXCLUDED or p.startswith(".") for p in rel.parts[:-1]):
            continue
        yield skill_md


totals = {p: 0 for p in POLICIES}
missing_deps: list[tuple[str, str]] = []
skill_count = 0

for tree in (HOME / "skills",):
    for skill_md in walk_skills(tree):
        skill_count += 1
        try:
            text = skill_md.read_text(encoding="utf-8")
        except OSError:
            totals["blocked_unknown"] += 1
            continue
        yaml_text = extract_frontmatter(text)
        policy = policy_for(yaml_text)
        totals[policy] += 1
        for dep in system_deps_for(yaml_text):
            if find_dep_binary(dep) is None:
                missing_deps.append((str(skill_md), dep))

print(f"  skills checked: {skill_count}")
for policy in (
    "stock_bundle_candidate",
    "provisioned_user_config_required",
    "external_runtime_only",
    "blocked_unknown",
):
    print(f"  {LABELS[policy]:<22} {totals[policy]:>3}  ({policy})")

fail_on = os.environ.get("HATCH_SKILL_READINESS_FAIL_ON", "blocked_unknown").strip()
fail = False
if fail_on:
    threshold_count = totals.get(fail_on, 0)
    if threshold_count > 0:
        if os.environ.get("HATCH_DRY_RUN", "true") == "true":
            print(f"  warn: {threshold_count} skill(s) at threshold '{fail_on}'", file=sys.stderr)
        else:
            print(f"  fail: {threshold_count} skill(s) at threshold '{fail_on}'", file=sys.stderr)
            fail = True

if missing_deps:
    print(
        f"  note: {len(missing_deps)} skill(s) declare system_dependencies that are not installed under "
        "~/.monoclaw/vendor/skill-deps/bin or ~/.monoclaw/vendor/mona-tools/bin"
    )
    for path, dep in missing_deps[:5]:
        print(f"    - {dep!r} required by {path}")
    if len(missing_deps) > 5:
        print(f"    ... ({len(missing_deps) - 5} more)")

sys.exit(1 if fail else 0)
PY

  if [[ ${exit_code} -ne 0 ]]; then
    if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
      log_warn "skill-readiness gate would fail (dry-run)"
    else
      die "skill-readiness gate failed"
    fi
  else
    log_ok "skill readiness audit passed"
  fi
}

run_install_skill_deps() {
  local home_dir
  local target_dir
  home_dir="$(monoclaw_home)"
  target_dir="${home_dir}/vendor/skill-deps"

  if [[ ! -d "${HATCH_SKILL_DEPS_PACK_ROOT}" ]]; then
    log_warn "No skill-deps pack at ${HATCH_SKILL_DEPS_PACK_ROOT}; nothing to install (default for current bundles)"
    return
  fi

  run_verify_skill_deps
  log_step "skill-deps" "Installing optional skill dependencies"
  log_action rm -rf "${target_dir}"
  log_action mkdir -p "${home_dir}/vendor"
  log_action cp -R "${HATCH_SKILL_DEPS_PACK_ROOT}" "${target_dir}"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: skill dependencies installed at %s\n' "${target_dir}"
  else
    log_ok "skill dependencies installed at ${target_dir}"
  fi
}

run_doctor() {
  run_preflight
  run_verify
  run_verify_local_inference
  run_verify_skill_readiness
  log_step "doctor" "Hatch doctor complete"
}

case "${COMMAND}" in
  preflight)
    run_preflight
    ;;
  prepare-bundle)
    run_prepare_bundle
    ;;
  cleanup-existing)
    cleanup_existing_runtime
    ;;
  install)
    run_install
    ;;
  verify)
    run_verify
    ;;
  verify-local-inference)
    run_verify_local_inference
    ;;
  verify-model-pack)
    run_verify_model_pack
    ;;
  install-model)
    run_install_model
    ;;
  verify-tools-pack)
    run_verify_tools_pack
    ;;
  install-tools)
    run_install_tools
    ;;
  verify-skill-deps)
    run_verify_skill_deps
    ;;
  install-skill-deps)
    run_install_skill_deps
    ;;
  verify-skill-readiness)
    run_verify_skill_readiness
    ;;
  doctor)
    run_doctor
    ;;
esac
