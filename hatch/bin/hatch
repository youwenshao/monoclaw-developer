#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HATCH_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
# shellcheck source=../lib/common.sh
source "${HATCH_ROOT}/lib/common.sh"

HATCH_DRY_RUN=true
COMMAND="preflight"
HATCH_BUNDLE_ROOT="${HATCH_ROOT}/dist"
HATCH_MODEL_PACK_ROOT=""
HATCH_TOOLS_PACK_ROOT=""
HATCH_SKILL_DEPS_PACK_ROOT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      HATCH_DRY_RUN=true
      shift
      ;;
    --apply|--no-dry-run)
      HATCH_DRY_RUN=false
      shift
      ;;
    --bundle-root)
      HATCH_BUNDLE_ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    --model-pack-root)
      HATCH_MODEL_PACK_ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    --tools-pack-root)
      HATCH_TOOLS_PACK_ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    --skill-deps-pack-root)
      HATCH_SKILL_DEPS_PACK_ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    prepare-bundle|preflight|cleanup-existing|install|verify|doctor|verify-local-inference|verify-model-pack|install-model|verify-tools-pack|install-tools|verify-skill-deps|install-skill-deps|install-core-deps|install-agent-browser|verify-skill-readiness)
      COMMAND="$1"
      shift
      ;;
    -h|--help)
      cat <<'HELP'
Hatch provisions Macs for MonoClaw.

Usage:
  hatch/bin/hatch [--dry-run|--apply] [--bundle-root dist] prepare-bundle
  hatch/bin/hatch [--dry-run|--apply] preflight
  hatch/bin/hatch [--dry-run|--apply] cleanup-existing
  hatch/bin/hatch [--dry-run|--apply] [--bundle-root dist] install
  hatch/bin/hatch [--dry-run|--apply] [--bundle-root dist] [--model-pack-root model-packs/gemma-4-e4b] install-model
  hatch/bin/hatch [--dry-run|--apply] [--bundle-root dist] [--tools-pack-root tool-packs/mona-secretary-tools] install-tools
  hatch/bin/hatch [--dry-run|--apply] [--bundle-root dist] [--skill-deps-pack-root tool-packs/skill-deps-pack] verify-skill-deps
  hatch/bin/hatch [--dry-run|--apply] [--bundle-root dist] [--skill-deps-pack-root tool-packs/skill-deps-pack] install-skill-deps
  hatch/bin/hatch [--dry-run|--apply] install-core-deps
  hatch/bin/hatch [--dry-run|--apply] install-agent-browser
  hatch/bin/hatch [--dry-run|--apply] verify
  hatch/bin/hatch [--dry-run|--apply] verify-local-inference
  hatch/bin/hatch [--dry-run|--apply] verify-skill-readiness
  hatch/bin/hatch [--dry-run|--apply] doctor

Hatch defaults to dry-run. Pass --apply only on a machine intended for provisioning.
HELP
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "${HATCH_MODEL_PACK_ROOT}" ]]; then
  HATCH_MODEL_PACK_ROOT="$(cd "${HATCH_BUNDLE_ROOT}/.." && pwd)/model-packs/gemma-4-e4b"
fi
if [[ -z "${HATCH_TOOLS_PACK_ROOT}" ]]; then
  HATCH_TOOLS_PACK_ROOT="$(cd "${HATCH_BUNDLE_ROOT}/.." && pwd)/tool-packs/mona-secretary-tools"
fi
if [[ -z "${HATCH_SKILL_DEPS_PACK_ROOT}" ]]; then
  HATCH_SKILL_DEPS_PACK_ROOT="$(cd "${HATCH_BUNDLE_ROOT}/.." && pwd)/tool-packs/skill-deps-pack"
fi

macos_version() {
  sw_vers -productVersion 2>/dev/null || printf 'unknown'
}

machine_arch() {
  uname -m 2>/dev/null || printf 'unknown'
}

is_macos() {
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]
}

warn_or_die() {
  local message="$1"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    log_warn "${message}"
  else
    die "${message}"
  fi
}

homebrew_executable() {
  if [[ "${HATCH_FORCE_HOMEBREW_MISSING:-0}" == "1" ]]; then
    return 1
  fi
  if have_command brew; then
    command -v brew
    return 0
  fi
  for candidate in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done
  return 1
}

activate_homebrew() {
  local brew_bin
  if ! brew_bin="$(homebrew_executable)"; then
    return 1
  fi
  eval "$("${brew_bin}" shellenv)"
  return 0
}

default_homebrew_prefix() {
  if [[ "$(machine_arch)" == "arm64" ]]; then
    printf '/opt/homebrew\n'
  else
    printf '/usr/local\n'
  fi
}

homebrew_prefix() {
  local brew_bin
  if brew_bin="$(homebrew_executable)"; then
    "${brew_bin}" --prefix 2>/dev/null || dirname "$(dirname "${brew_bin}")"
  else
    default_homebrew_prefix
  fi
}

prepend_path_var() {
  local var_name="$1"
  local value="$2"
  local current="${!var_name:-}"

  if [[ -z "${current}" ]]; then
    export "${var_name}=${value}"
  elif [[ ":${current}:" != *":${value}:"* ]]; then
    export "${var_name}=${value}:${current}"
  fi
}

install_homebrew_if_missing() {
  local brew_bin

  if brew_bin="$(homebrew_executable)"; then
    activate_homebrew || true
    log_ok "Homebrew found at ${brew_bin}"
    return
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: install Homebrew with official installer\n'
    printf '  dry-run: /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"\n'
    return
  fi

  if [[ "${HATCH_SKIP_HOMEBREW_INSTALL:-0}" == "1" ]]; then
    log_warn "Skipping Homebrew installation because HATCH_SKIP_HOMEBREW_INSTALL=1"
    return
  fi

  log_warn "Homebrew missing; installing with the official Homebrew installer"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if activate_homebrew; then
    log_ok "Homebrew installed and activated for this shell"
  else
    die "Homebrew installation finished but brew was not found; open a new terminal or run /opt/homebrew/bin/brew shellenv, then rerun Hatch"
  fi
}

ensure_runtime_python_available() {
  local home_dir
  local runtime_python
  home_dir="$(monoclaw_home)"

  if [[ "${HATCH_SKIP_RUNTIME_BOOTSTRAP:-0}" == "1" ]]; then
    log_warn "Skipping Python 3.11+ runtime check because HATCH_SKIP_RUNTIME_BOOTSTRAP=1"
    return
  fi

  if runtime_python="$(select_runtime_python "${home_dir}")"; then
    log_ok "Python 3.11+ runtime interpreter available at ${runtime_python} ($(python_version_string "${runtime_python}"))"
    return
  fi

  if runtime_python="$(select_bundle_runtime_python)"; then
    log_ok "Python 3.11+ runtime interpreter available at ${runtime_python} ($(python_version_string "${runtime_python}"))"
    return
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    log_warn "Python 3.11+ runtime interpreter missing; bundle vendor/python/current/bin/python3"
    return
  fi

  die "Python 3.11+ runtime interpreter missing; rebuild the bundle with vendor/python/current/bin/python3"
}

check_manual_prerequisites() {
  log_step "preflight" "Checking manual macOS prerequisites"

  if is_macos; then
    if command -v xcode-select >/dev/null 2>&1 && xcode-select -p >/dev/null 2>&1; then
      log_ok "Xcode Command Line Tools are installed"
    else
      warn_or_die "Xcode Command Line Tools are missing; run xcode-select --install and complete the macOS prompt"
    fi
  else
    log_warn "Xcode Command Line Tools check skipped; Hatch target installs are intended for macOS"
  fi

  if [[ -d "/Applications/Docker.app" ]]; then
    log_ok "Docker Desktop app is present"
  else
    log_warn "Docker Desktop is not installed; install it manually if sandboxed tools are required"
  fi
}

check_bundle() {
  log_step "bundle" "Verifying prepared Hatch bundle"
  if [[ -f "${HATCH_BUNDLE_ROOT}/hatch-manifest.json" ]]; then
    verify_bundle_manifest "${HATCH_BUNDLE_ROOT}" | sed 's/^/  ok: /'
  else
    log_warn "No Hatch manifest found at ${HATCH_BUNDLE_ROOT}/hatch-manifest.json"
  fi
}

check_terminal_dependencies() {
  log_step "preflight" "Checking terminal-manageable dependencies"

  local required=(curl)
  for cmd in "${required[@]}"; do
    if have_command "${cmd}"; then
      log_ok "${cmd} found"
    else
      warn_or_die "${cmd} missing"
    fi
  done

  install_homebrew_if_missing
  ensure_runtime_python_available

  if lm_studio_app_installed; then
    log_ok "LM Studio app is present"
  else
    log_warn "LM Studio app is missing; install it manually from the official .dmg if local inference is required"
  fi
}

cleanup_existing_runtime() {
  log_step "cleanup" "Detecting existing MonoClaw and legacy runtimes"

  if have_command monoclaw; then
    local monoclaw_venv_bin
    monoclaw_venv_bin="$(monoclaw_home)/vendor/runtime/venv/bin/monoclaw"
    if [[ -x "${monoclaw_venv_bin}" ]]; then
      # Set HATCH_AUTO_UNINSTALL=0 to skip the uninstall-wizard prompt and run
      # the standard gateway cleanup instead (e.g. for headless provisioning).
      if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
        printf '  dry-run: existing MonoClaw install detected; would offer uninstall wizard [Y/n]\n'
        log_action monoclaw gateway stop
        log_action monoclaw gateway uninstall
      elif [[ "${HATCH_AUTO_UNINSTALL:-1}" == "0" ]]; then
        printf '  info: HATCH_AUTO_UNINSTALL=0; skipping uninstall prompt\n' >&2
        log_action monoclaw gateway stop
        log_action monoclaw gateway uninstall
      elif [[ -t 0 && -t 1 ]]; then
        printf '\n  An existing MonoClaw installation was detected.\n'
        printf '  Run the MonoClaw uninstall wizard before reinstalling? [Y/n] '
        read -r _UNINSTALL_ANSWER || true
        if [[ -z "${_UNINSTALL_ANSWER}" ]] || [[ "${_UNINSTALL_ANSWER}" =~ ^[Yy] ]]; then
          export PATH="${HOME}/.local/bin:${PATH}"
          monoclaw uninstall || true
        else
          log_action monoclaw gateway stop
          log_action monoclaw gateway uninstall
        fi
      else
        log_action monoclaw gateway stop
        log_action monoclaw gateway uninstall
      fi
    else
      log_warn "monoclaw shim found but runtime venv is missing or incomplete; skipping gateway cleanup"
    fi
  else
    log_ok "monoclaw command not found"
  fi

  if have_command hermes; then
    log_action hermes gateway stop
    log_action hermes gateway uninstall
  else
    log_ok "legacy runtime command not found"
  fi

  for label in app.monoclaw.gateway ai.hermes.gateway; do
    if detect_launch_agent "${label}"; then
      log_action launchctl bootout "gui/$(id -u)/${label}"
    else
      log_ok "launchd label ${label} not loaded"
    fi
  done
}

run_preflight() {
  log_step "system" "macOS $(macos_version), architecture $(machine_arch)"
  check_manual_prerequisites
  check_terminal_dependencies
  check_bundle
}

run_prepare_bundle() {
  log_step "prepare-bundle" "Checking prepared Hatch bundle"
  verify_bundle_manifest "${HATCH_BUNDLE_ROOT}" | sed 's/^/  ok: /'
}

runtime_manifest_field() {
  local field="$1"
  local python_bin
  python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}")"
  PYTHONDONTWRITEBYTECODE=1 HATCH_BUNDLE_ROOT="${HATCH_BUNDLE_ROOT}" "${python_bin}" - "${field}" <<'PY'
import json
import os
import sys
from pathlib import Path

field = sys.argv[1]
manifest = Path(os.environ["HATCH_BUNDLE_ROOT"]) / "hatch-manifest.json"
data = json.loads(manifest.read_text(encoding="utf-8"))
value = data.get("runtime", {}).get(field, "")
if value:
    print(value)
PY
}

is_valid_wheel_filename() {
  local wheel_path="$1"
  local python_bin
  python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}")"
  PYTHONDONTWRITEBYTECODE=1 "${python_bin}" - "${wheel_path}" <<'PY'
import sys
from pathlib import Path

name = Path(sys.argv[1]).name
if not name.endswith(".whl"):
    raise SystemExit(1)
stem = name[:-4]
parts = stem.split("-")
# PEP 427: distribution-version(-build tag)-python tag-abi tag-platform tag
if len(parts) < 5:
    raise SystemExit(1)
PY
}

python_satisfies_runtime() {
  local python_bin="$1"
  [[ -x "${python_bin}" ]] || return 1
  PYTHONDONTWRITEBYTECODE=1 "${python_bin}" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' >/dev/null 2>&1
}

python_version_string() {
  local python_bin="$1"
  PYTHONDONTWRITEBYTECODE=1 "${python_bin}" -c 'import sys; print(".".join(map(str, sys.version_info[:3])))' 2>/dev/null || printf 'unknown'
}

select_runtime_python() {
  local home_dir="$1"
  local candidate
  local candidates=()

  if [[ "${HATCH_FORCE_RUNTIME_PYTHON_MISSING:-0}" == "1" ]]; then
    return 1
  fi

  if [[ -n "${HATCH_RUNTIME_PYTHON:-}" ]]; then
    candidates+=("${HATCH_RUNTIME_PYTHON}")
  fi
  candidates+=("${home_dir}/vendor/python/current/bin/python3")
  candidates+=("${home_dir}/vendor/python/current/bin/python3.13")
  candidates+=("${home_dir}/vendor/python/current/bin/python3.12")
  candidates+=("${home_dir}/vendor/python/current/bin/python3.11")

  # HATCH_ALLOW_SYSTEM_RUNTIME_PYTHON has been moved to hatch-diagnostics.
  # The production install path is bundle-only per hatch/CLAUDE.md policy.

  for candidate in "${candidates[@]}"; do
    if python_satisfies_runtime "${candidate}"; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

select_bundle_runtime_python() {
  local candidate
  local candidates=()

  if [[ "${HATCH_FORCE_RUNTIME_PYTHON_MISSING:-0}" == "1" ]]; then
    return 1
  fi

  candidates+=("${HATCH_BUNDLE_ROOT}/vendor/python/current/bin/python3")
  candidates+=("${HATCH_BUNDLE_ROOT}/vendor/python/current/bin/python3.13")
  candidates+=("${HATCH_BUNDLE_ROOT}/vendor/python/current/bin/python3.12")
  candidates+=("${HATCH_BUNDLE_ROOT}/vendor/python/current/bin/python3.11")

  for candidate in "${candidates[@]}"; do
    if python_satisfies_runtime "${candidate}"; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

install_runtime_assets() {
  local home_dir
  home_dir="$(monoclaw_home)"

  log_step "install" "Installing manifest-verified runtime assets"
  log_action mkdir -p "${home_dir}/vendor"
  log_action mkdir -p "${home_dir}/customer"
  log_action mkdir -p "${home_dir}/logs"
  log_action cp "${HATCH_BUNDLE_ROOT}/hatch-manifest.json" "${home_dir}/vendor/hatch-manifest.json"

  if [[ -f "${HATCH_BUNDLE_ROOT}/LICENSE.md" ]]; then
    log_action cp "${HATCH_BUNDLE_ROOT}/LICENSE.md" "${home_dir}/LICENSE.md"
  fi

  if [[ -d "${HATCH_BUNDLE_ROOT}/runtime" ]]; then
    log_action rm -rf "${home_dir}/vendor/runtime"
    log_action cp -R "${HATCH_BUNDLE_ROOT}/runtime" "${home_dir}/vendor/runtime"
  else
    log_warn "Bundle runtime directory missing; manifest may describe an external wheel-only bundle"
  fi

  # ``tui`` and ``whatsapp-bridge`` are Node subsystems the runtime expects
  # to find under ``$MONOCLAW_HOME/vendor/`` (see ``_resolve_tui_dir`` and
  # ``_resolve_bridge_dir`` in monoclaw-runtime).  Without these, ``monoclaw
  # --tui`` crashes with FileNotFoundError on cwd and ``monoclaw whatsapp``
  # exits at "Bridge script not found" — the May 2026 incident.
  for asset in python support lm-studio models browser skills optional-skills \
              launchd wheelhouse provisioning tui whatsapp-bridge; do
    if [[ -d "${HATCH_BUNDLE_ROOT}/vendor/${asset}" ]]; then
      log_action rm -rf "${home_dir}/vendor/${asset}"
      log_action cp -R "${HATCH_BUNDLE_ROOT}/vendor/${asset}" "${home_dir}/vendor/${asset}"
    fi
  done
}

_run_warm_npm_install() {
  # Shared diagnostic-rich npm install runner for both warm_*_install
  # functions. Captures stderr so the technician sees the real failure
  # cause inline (May 2026 incident: the prior ``>/dev/null 2>&1`` swallow
  # produced a bare "WhatsApp bridge npm install failed" with no context,
  # exactly the same UX problem the runtime side just fixed for the TUI).
  #
  # Arguments: $1=label  $2=directory  $3=strict-mode-env-name
  # ``--loglevel=error`` mirrors the runtime's ``_npm_install_args``:
  # success is one line ("added N packages in Ms"), failure preserves
  # the actual npm error chain.
  local label="$1"
  local dir="$2"
  local strict_env="$3"
  local strict_flag="${!strict_env:-0}"

  local stderr_log
  stderr_log="$(mktemp -t "hatch-npm-${label// /-}-stderr.XXXXXX")"

  local rc=0
  ( cd "${dir}" && npm install --loglevel=error --no-fund --no-audit --progress=false ) 2> "${stderr_log}" || rc=$?

  if [[ "${rc}" == "0" ]]; then
    rm -f "${stderr_log}"
    log_ok "${label} dependencies installed at ${dir}/node_modules"
    return 0
  fi

  # Surface npm's actual error: tail to 50 lines so peer-dep traces
  # survive but we don't dump megabytes of verbose output.
  printf '  --- npm stderr (exit %d) ---\n' "${rc}" >&2
  tail -n 50 "${stderr_log}" | sed 's/^/  /' >&2

  # Point at npm's full debug log so the technician can investigate
  # without re-running. npm always writes one regardless of loglevel.
  local newest_log
  newest_log="$(ls -t "${HOME}/.npm/_logs/"*-debug-0.log 2>/dev/null | head -n 1)"
  if [[ -n "${newest_log}" ]]; then
    printf '  full log: %s\n' "${newest_log}" >&2
  fi
  printf '  retry manually with verbose output:\n    cd %s && npm install --loglevel=verbose\n' "${dir}" >&2
  rm -f "${stderr_log}"

  if [[ "${strict_flag}" == "1" ]]; then
    die "${label} npm install failed (${strict_env}=1)"
  fi
  log_warn "${label} npm install failed; ${label} will retry on first use"
  return 0
}

warm_whatsapp_bridge_install() {
  # Run ``npm install`` against the staged ``vendor/whatsapp-bridge/`` so the
  # customer Mac has the bridge ready when they later run ``monoclaw whatsapp``.
  # The wizard has its own ``npm install`` fallback for dev-mode installs,
  # but in the canonical Hatch path we want the bridge hot at provision
  # time — the wizard is otherwise a 60-120s blackout on a cold npm cache.
  #
  # Non-fatal by default: if the customer Mac is offline at install time,
  # we log a warning and let the wizard retry later. Set
  # ``HATCH_REQUIRE_WHATSAPP_BRIDGE_INSTALL=1`` to upgrade the warning to a
  # hard fail when install-time guarantees are required (e.g. lab provisioning).
  local home_dir
  home_dir="$(monoclaw_home)"
  local bridge_dir="${home_dir}/vendor/whatsapp-bridge"

  if [[ ! -f "${bridge_dir}/package.json" ]]; then
    log_warn "WhatsApp bridge not staged at ${bridge_dir}; skipping npm install warmup"
    return 0
  fi

  if [[ -d "${bridge_dir}/node_modules" ]]; then
    log_ok "WhatsApp bridge node_modules already present"
    return 0
  fi

  if ! have_command npm; then
    if [[ "${HATCH_REQUIRE_WHATSAPP_BRIDGE_INSTALL:-0}" == "1" ]]; then
      die "WhatsApp bridge npm install required but npm is not on PATH"
    fi
    log_warn "npm not on PATH; skipping WhatsApp bridge install (run \`monoclaw whatsapp\` later to install)"
    return 0
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: npm install --loglevel=error --no-fund --no-audit --progress=false in %s\n' "${bridge_dir}"
    return 0
  fi

  log_step "install" "Warming WhatsApp bridge dependencies (one-time)"
  _run_warm_npm_install "WhatsApp bridge" "${bridge_dir}" "HATCH_REQUIRE_WHATSAPP_BRIDGE_INSTALL"
}

warm_tui_install() {
  # Run ``npm install`` against the staged ``vendor/tui/`` so the customer's
  # first ``monoclaw --tui`` invocation isn't a 30-90s blackout (and, more
  # importantly, isn't where any install failure first surfaces — see
  # plans/tui-npm-install-error-handling.md for the May 2026 test-bench
  # report). The runtime's ``_make_tui_argv`` keeps its on-demand install
  # path as a fallback for git-editable installs and for cases where this
  # warmup was skipped (offline at install time, npm missing, etc.).
  #
  # Non-fatal by default; set ``HATCH_REQUIRE_TUI_INSTALL=1`` for lab
  # provisioning where the operator wants an install-time guarantee.
  # Set ``HATCH_SKIP_TUI_WARMUP=1`` to skip entirely (e.g. for tight
  # provisioning windows where the 30-90s cost matters more than the
  # better UX).
  local home_dir
  home_dir="$(monoclaw_home)"
  local tui_dir="${home_dir}/vendor/tui"

  if [[ "${HATCH_SKIP_TUI_WARMUP:-0}" == "1" ]]; then
    log_ok "TUI npm install skipped (HATCH_SKIP_TUI_WARMUP=1); \`monoclaw --tui\` will install on first run"
    return 0
  fi

  if [[ ! -f "${tui_dir}/package.json" ]]; then
    log_warn "TUI not staged at ${tui_dir}; skipping npm install warmup"
    return 0
  fi

  if [[ -d "${tui_dir}/node_modules" ]]; then
    log_ok "TUI node_modules already present"
    return 0
  fi

  if ! have_command npm; then
    if [[ "${HATCH_REQUIRE_TUI_INSTALL:-0}" == "1" ]]; then
      die "TUI npm install required but npm is not on PATH"
    fi
    log_warn "npm not on PATH; skipping TUI install (run \`monoclaw --tui\` later to install)"
    return 0
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: npm install --loglevel=error --no-fund --no-audit --progress=false in %s\n' "${tui_dir}"
    return 0
  fi

  log_step "install" "Warming TUI dependencies (one-time, ~30-90s on cold cache)"
  _run_warm_npm_install "TUI" "${tui_dir}" "HATCH_REQUIRE_TUI_INSTALL"
}

ensure_local_bin_on_path() {
  local user_home="$1"
  local command_link_dir="${user_home}/.local/bin"
  local shell_name
  local shell_config
  shell_name="$(basename "${SHELL:-/bin/zsh}")"

  if [[ ":${PATH}:" == *":${command_link_dir}:"* ]]; then
    log_ok "${command_link_dir} already on PATH"
    return
  fi

  case "${shell_name}" in
    zsh)
      shell_config="${user_home}/.zshrc"
      ;;
    bash)
      if [[ -f "${user_home}/.bash_profile" ]]; then
        shell_config="${user_home}/.bash_profile"
      else
        shell_config="${user_home}/.bashrc"
      fi
      ;;
    *)
      shell_config="${user_home}/.zshrc"
      ;;
  esac

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: append ~/.local/bin PATH export to %s\n' "${shell_config}"
    return
  fi

  mkdir -p "$(dirname "${shell_config}")"
  touch "${shell_config}"
  if grep -v '^[[:space:]]*#' "${shell_config}" 2>/dev/null | grep -qE 'PATH=.*\.local/bin'; then
    log_ok "${shell_config} already configures ~/.local/bin"
    return
  fi

  {
    printf '\n'
    printf '# MonoClaw Runtime - ensure ~/.local/bin is on PATH\n'
    printf 'export PATH="$HOME/.local/bin:$PATH"\n'
  } >> "${shell_config}"
  log_ok "Added ~/.local/bin to PATH in ${shell_config}"
}

write_monoclaw_shim() {
  local user_home="$1"
  local venv_dir="$2"
  local command_link_dir="${user_home}/.local/bin"
  local shim="${command_link_dir}/monoclaw"

  log_action mkdir -p "${command_link_dir}"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: write %s shim\n' "${shim}"
    log_action chmod +x "${shim}"
    ensure_local_bin_on_path "${user_home}"
    return
  fi

  cat > "${shim}" <<EOF
#!/usr/bin/env bash
unset PYTHONPATH
unset PYTHONHOME
if [[ -d "${user_home}/.monoclaw/vendor/skills" ]]; then
  export MONOCLAW_BUNDLED_SKILLS="${user_home}/.monoclaw/vendor/skills"
fi
if [[ -d "${user_home}/.monoclaw/vendor/optional-skills" ]]; then
  export MONOCLAW_OPTIONAL_SKILLS="${user_home}/.monoclaw/vendor/optional-skills"
fi
exec "${venv_dir}/bin/monoclaw" "\$@"
EOF
  chmod +x "${shim}"
  log_ok "monoclaw command shim installed at ${shim}"
  ensure_local_bin_on_path "${user_home}"
}

create_runtime_venv() {
  local runtime_python="$1"
  local venv_dir="$2"

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    log_action rm -rf "${venv_dir}"
    if [[ "${HATCH_TEST_VENV_ENSUREPIP_FAIL:-0}" == "1" ]]; then
      warn_or_die "Bundled Python failed to create a pip-capable venv; rebuild the bundle with a working Python runtime"
    else
      log_action "${runtime_python}" -m venv "${venv_dir}"
    fi
    return
  fi

  rm -rf "${venv_dir}"
  if "${runtime_python}" -m venv "${venv_dir}"; then
    return
  fi

  die "Bundled Python failed to create a pip-capable venv; rebuild the bundle with a working Python runtime"
}

bootstrap_runtime() {
  local home_dir
  local runtime_dir
  local venv_dir
  local wheel
  local wheel_to_check
  local wheel_rel
  local wheelhouse
  local pip_wheel
  local package_spec
  local runtime_version
  local fallback_version
  local runtime_python
  local pip_install_base
  home_dir="$(monoclaw_home)"
  runtime_dir="${home_dir}/vendor/runtime"
  venv_dir="${runtime_dir}/venv"
  wheel_rel="$(runtime_manifest_field wheel)"
  runtime_version="$(runtime_manifest_field version)"
  if [[ -z "${wheel_rel}" ]]; then
    wheel_rel="runtime/monoclaw-runtime.whl"
  fi
  if [[ -z "${runtime_version}" ]]; then
    runtime_version="0.0.0"
  fi
  wheel="${home_dir}/vendor/${wheel_rel}"
  wheel_to_check="${wheel}"
  wheelhouse="${home_dir}/vendor/wheelhouse"
  pip_wheel="${wheel}"

  log_step "install" "Bootstrapping MonoClaw runtime"

  if [[ "${HATCH_SKIP_RUNTIME_BOOTSTRAP:-0}" == "1" ]]; then
    log_warn "Skipping runtime bootstrap because HATCH_SKIP_RUNTIME_BOOTSTRAP=1"
    return
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    wheel_to_check="${HATCH_BUNDLE_ROOT}/${wheel_rel}"
  fi

  if [[ ! -f "${wheel_to_check}" ]]; then
    warn_or_die "Runtime wheel missing at ${wheel}"
    return
  fi

  if ! runtime_python="$(select_runtime_python "${home_dir}")"; then
    warn_or_die "Python 3.11+ is required for MonoClaw runtime bootstrap; bundle vendor/python/current/bin/python3 or install Python 3.11+ before rerunning"
    return
  fi

  log_ok "Using Python ${runtime_python} ($(python_version_string "${runtime_python}")) for runtime bootstrap"

  if ! is_valid_wheel_filename "${wheel_to_check}"; then
    fallback_version="${runtime_version//-/_}"
    pip_wheel="${runtime_dir}/.hatch-install/monoclaw_runtime-${fallback_version}-py3-none-any.whl"
  fi
  package_spec="${pip_wheel}[local-office]"

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    create_runtime_venv "${runtime_python}" "${venv_dir}"
    if [[ "${pip_wheel}" != "${wheel}" ]]; then
      log_action mkdir -p "$(dirname "${pip_wheel}")"
      log_action cp "${wheel}" "${pip_wheel}"
    fi
    if [[ -d "${HATCH_BUNDLE_ROOT}/vendor/wheelhouse" ]]; then
      pip_install_base=("${venv_dir}/bin/python" -m pip install --no-index --find-links "${wheelhouse}")
      log_action "${pip_install_base[@]}" --upgrade pip setuptools wheel
      log_action "${pip_install_base[@]}" "${package_spec}"
    else
      # HATCH_ALLOW_RUNTIME_NETWORK_FALLBACK has been moved to hatch-diagnostics.
      # Production installs require a bundled wheelhouse — no live PyPI access.
      warn_or_die "Bundled wheelhouse is required for production runtime bootstrap; rebuild with build.sh"
    fi
    write_monoclaw_shim "${HOME}" "${venv_dir}"
    return
  fi

  create_runtime_venv "${runtime_python}" "${venv_dir}"
  if [[ "${pip_wheel}" != "${wheel}" ]]; then
    mkdir -p "$(dirname "${pip_wheel}")"
    cp "${wheel}" "${pip_wheel}"
  fi
  if [[ -d "${wheelhouse}" ]] && [[ -n "$(ls -A "${wheelhouse}" 2>/dev/null || true)" ]]; then
    "${venv_dir}/bin/python" -m pip install --no-index --find-links "${wheelhouse}" --upgrade pip setuptools wheel
    "${venv_dir}/bin/python" -m pip install --no-index --find-links "${wheelhouse}" "${package_spec}"
  else
    # Production path: wheelhouse is required. HATCH_ALLOW_RUNTIME_NETWORK_FALLBACK
    # has been removed from this path and moved to hatch-diagnostics for repair use only.
    die "Bundled wheelhouse is required for production runtime bootstrap; rebuild the bundle with build.sh on the assembly machine"
  fi
  log_ok "MonoClaw runtime installed into ${venv_dir}"
  write_monoclaw_shim "${HOME}" "${venv_dir}"
}

initialize_skills_hub_dir() {
  # Pre-create ``~/.monoclaw/skills/.hub/`` so doctor's "Skills Hub
  # directory not initialized" check passes on a fresh install.
  # Pre-2026-05 the directory was created lazily on the first
  # ``monoclaw skills list`` call, which means the very first
  # ``monoclaw doctor`` after install always emitted a misleading
  # "run: monoclaw skills list" warning. Seeding here is harmless: the
  # CLI continues to lazily upgrade the directory's schema as needed.
  local home_dir hub_dir lock_file
  home_dir="$(monoclaw_home)"
  hub_dir="${home_dir}/skills/.hub"
  lock_file="${hub_dir}/lock.json"

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    if [[ ! -d "${hub_dir}" ]]; then
      printf '  dry-run: mkdir -p %s\n' "${hub_dir}"
    fi
    if [[ ! -f "${lock_file}" ]]; then
      printf '  dry-run: write empty lock file at %s\n' "${lock_file}"
    fi
    return
  fi

  mkdir -p "${hub_dir}"
  # Only seed the lock file when it does not exist — never overwrite a
  # pre-existing one (could destroy hub-installed skill metadata).
  if [[ ! -f "${lock_file}" ]]; then
    printf '{"installed": {}}\n' > "${lock_file}"
    log_ok "Initialized Skills Hub at ${hub_dir}"
  else
    log_ok "Skills Hub already initialized at ${hub_dir}"
  fi
}

install_bundled_skills() {
  local home_dir
  local source_dir
  local target_dir
  home_dir="$(monoclaw_home)"
  source_dir="${home_dir}/vendor/skills"
  target_dir="${home_dir}/skills"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    source_dir="${HATCH_BUNDLE_ROOT}/vendor/skills"
  fi

  if [[ ! -d "${source_dir}" ]]; then
    log_warn "No bundled skills staged at ${home_dir}/vendor/skills"
    return
  fi

  log_step "install" "Installing bundled skills"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: install bundled skills into %s\n' "${target_dir}"
    return
  fi

  mkdir -p "${target_dir}"
  for skill_path in "${source_dir}"/*; do
    [[ -e "${skill_path}" ]] || continue
    local skill_name
    skill_name="$(basename "${skill_path}")"
    if [[ -e "${target_dir}/${skill_name}" ]]; then
      log_warn "Keeping existing skill ${target_dir}/${skill_name}"
      continue
    fi
    cp -R "${skill_path}" "${target_dir}/${skill_name}"
  done
  log_ok "Bundled skills installed into ${target_dir}"
}

write_setup_config_handoff() {
  local home_dir
  home_dir="$(monoclaw_home)"

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    if [[ -f "${home_dir}/.env" ]]; then
      printf '  dry-run: keep existing %s\n' "${home_dir}/.env"
    else
      printf '  dry-run: leave %s for monoclaw onboard\n' "${home_dir}/.env"
    fi
    if [[ -f "${home_dir}/config.yaml" ]]; then
      printf '  dry-run: keep existing %s\n' "${home_dir}/config.yaml"
    else
      printf '  dry-run: leave %s for monoclaw onboard\n' "${home_dir}/config.yaml"
    fi
    return
  fi

  if [[ -f "${home_dir}/.env" ]]; then
    log_warn "Keeping existing ${home_dir}/.env"
  else
    log_warn "No ${home_dir}/.env written; end user runs monoclaw onboard for provider and secret configuration"
  fi

  if [[ -f "${home_dir}/config.yaml" ]]; then
    log_warn "Keeping existing ${home_dir}/config.yaml"
  else
    log_warn "No ${home_dir}/config.yaml written; technician provision writes safe defaults; end user runs monoclaw onboard"
  fi
}

lm_studio_app_path() {
  printf '%s\n' "${HATCH_LM_STUDIO_APP_PATH:-/Applications/LM Studio.app}"
}

gemma_lmstudio_models_dir() {
  printf '%s/.lmstudio/models/lmstudio-community/gemma-4-E4B-it-GGUF\n' "${HOME}"
}

lm_studio_app_installed() {
  [[ -d "$(lm_studio_app_path)" ]]
}

print_manual_local_inference_handoff() {
  local gemma_dir
  gemma_dir="$(gemma_lmstudio_models_dir)"
  log_step "install" "Manual local inference handoff"
  printf '  manual: install LM Studio from the official .dmg before ./install-gemma-model.sh\n'
  printf '  manual: install Docker Desktop from the official .dmg if sandboxed tools are required\n'
  printf '  manual: use ./install-gemma-model.sh when the optional Gemma model pack is present on the pendrive\n'
  printf '  manual: after install-model, launch LM Studio once; models load from %s\n' "${gemma_dir}"
}

print_technician_handoff() {
  log_step "install" "Technician handoff"
  printf '  next: open a new terminal or run: export PATH="%s/.local/bin:$PATH"\n' "${HOME}"
  printf '  next: verify runtime with: monoclaw --version\n'
  printf '  next: ship this Mac — end user runs: monoclaw onboard\n'
  printf '        (install.sh runs monoclaw provision --non-interactive automatically)\n'
}

run_install() {
  run_prepare_bundle
  log_step "system" "macOS $(macos_version), architecture $(machine_arch)"
  check_manual_prerequisites
  check_terminal_dependencies
  cleanup_existing_runtime
  install_runtime_assets
  write_setup_config_handoff
  bootstrap_runtime
  install_bundled_skills
  initialize_skills_hub_dir
  # Pre-2026-05 ``run_install`` skipped the core-deps + agent-browser
  # provisioning entirely; those steps only ran via the optional
  # skill-deps pack (``run_install_skill_deps``) which is absent in the
  # default local-office bundle. Result: every fresh customer Mac came up
  # without ``rg``, ``ffmpeg``, or ``agent-browser`` and ``monoclaw doctor
  # --fix`` flagged each as a manual fix item. Wiring them here closes
  # that gap. The standalone ``bin/hatch install-core-deps`` command and
  # the ``run_install_skill_deps`` flow remain idempotent thanks to
  # ``brew install --quiet`` and ``npm install -g``.
  install_class_a_brew_formulas
  run_install_core_deps
  run_install_agent_browser
  # Warm the WhatsApp bridge's node_modules so the customer's first
  # ``monoclaw whatsapp`` run isn't a 60-120s blackout on a cold npm cache.
  # Non-fatal: if the customer is offline the wizard retries later.
  warm_whatsapp_bridge_install
  # Same logic for the TUI's node_modules so the customer's first
  # ``monoclaw --tui`` invocation isn't where install failures first
  # surface (May 2026 incident — see
  # plans/tui-npm-install-error-handling.md). Non-fatal by default;
  # ``HATCH_REQUIRE_TUI_INSTALL=1`` upgrades to a hard failure for
  # lab provisioning, and ``HATCH_SKIP_TUI_WARMUP=1`` opts out for
  # tight provisioning windows.
  warm_tui_install
  print_manual_local_inference_handoff
  print_technician_handoff
  log_step "install" "Service bootstrap scaffold"
  log_warn "launchd service installation is not enabled until bundle plists are finalized"
}

run_verify() {
  local home_dir
  local monoclaw_bin
  home_dir="$(monoclaw_home)"

  log_step "verify" "Checking first-run readiness"

  # ── File/directory presence (structural) ────────────────────────────────
  if [[ -d "${home_dir}" ]]; then
    log_ok "MonoClaw home exists at ${home_dir}"
  else
    warn_or_die "MonoClaw home does not exist at ${home_dir}"
  fi

  if [[ -d "${home_dir}/vendor/runtime" ]]; then
    log_ok "vendor runtime assets present"
  else
    warn_or_die "vendor runtime assets are missing"
  fi

  if [[ -x "${home_dir}/vendor/runtime/venv/bin/monoclaw" ]]; then
    log_ok "monoclaw venv entrypoint present"
  else
    warn_or_die "monoclaw venv entrypoint is missing"
  fi

  if [[ -x "${HOME}/.local/bin/monoclaw" ]]; then
    monoclaw_bin="${HOME}/.local/bin/monoclaw"
    log_ok "monoclaw command shim present at ${monoclaw_bin}"
  elif [[ -x "${home_dir}/vendor/runtime/venv/bin/monoclaw" ]]; then
    monoclaw_bin="${home_dir}/vendor/runtime/venv/bin/monoclaw"
    log_warn "monoclaw shim at ${HOME}/.local/bin/monoclaw missing; using venv directly"
  else
    warn_or_die "monoclaw command not found; check PATH and venv"
    monoclaw_bin=""
  fi

  if [[ -f "${home_dir}/vendor/hatch-manifest.json" ]]; then
    log_ok "installed Hatch manifest present"
  else
    log_warn "installed Hatch manifest is missing"
  fi

  if [[ -d "${home_dir}/skills" ]] && [[ -n "$(ls -A "${home_dir}/skills" 2>/dev/null || true)" ]]; then
    log_ok "bundled skills installed"
  else
    log_warn "bundled skills are missing"
  fi

  if [[ -d "${home_dir}/logs" && -w "${home_dir}/logs" ]]; then
    log_ok "logs directory is writable"
  else
    log_warn "logs directory is missing or not writable"
  fi

  # ── Behavioral smoke probes ──────────────────────────────────────────────
  # These fail the verify step rather than just warning, because a successful
  # file-presence check that hides a broken runtime is worse than no check.
  if [[ -z "${monoclaw_bin:-}" ]]; then
    warn_or_die "Skipping behavioral probes: monoclaw binary not found"
    return
  fi

  # Layered behavioral probes:
  #   1) import the wheel directly from the runtime venv (catches missing
  #      module / broken install / wrong-Python-version cases with a cleaner
  #      error than a full CLI entrypoint failure).
  #   2) run `monoclaw --version` (catches entry_point wiring and minimal
  #      transitive-dep load).
  #   3) run `monoclaw doctor --json` (full health check).
  local venv_python="${home_dir}/vendor/runtime/venv/bin/python"
  if [[ -x "${venv_python}" ]]; then
    log_step "verify" "Importing monoclaw_runtime from the runtime venv"
    local import_out=""
    local import_exit=0
    import_out="$(hatch_run_with_timeout 10 "${venv_python}" -c 'import monoclaw_runtime; print(getattr(monoclaw_runtime, "__version__", "unknown"))' 2>&1)" || import_exit=$?
    if [[ "${import_exit}" -eq 0 ]]; then
      log_ok "monoclaw_runtime imported (version ${import_out})"
    elif [[ "${import_exit}" -eq 124 ]]; then
      warn_or_die "monoclaw_runtime import timed out after 10s (venv may be corrupted)"
      return
    else
      warn_or_die "monoclaw_runtime import failed (exit ${import_exit}): ${import_out}. Reinstall the runtime wheel into ${home_dir}/vendor/runtime/venv."
      return
    fi
  else
    log_warn "Skipping monoclaw_runtime import probe: venv python not found at ${venv_python}"
  fi

  log_step "verify" "Running monoclaw --version smoke probe"
  local version_out=""
  local version_exit=0
  version_out="$(hatch_run_with_timeout 15 "${monoclaw_bin}" --version 2>&1)" || version_exit=$?
  if [[ "${version_exit}" -eq 0 ]]; then
    log_ok "monoclaw --version: ${version_out}"
  elif [[ "${version_exit}" -eq 124 ]]; then
    warn_or_die "monoclaw --version timed out after 15s"
    return
  else
    warn_or_die "monoclaw --version failed (exit ${version_exit}): ${version_out}"
    return
  fi

  log_step "verify" "Running monoclaw doctor --json probe"
  local doctor_out=""
  local doctor_exit=0
  doctor_out="$(hatch_run_with_timeout 30 "${monoclaw_bin}" doctor --json 2>&1)" || doctor_exit=$?
  if [[ "${doctor_exit}" -eq 0 ]]; then
    log_ok "monoclaw doctor: all essential checks green"
  elif [[ "${doctor_exit}" -eq 124 ]]; then
    warn_or_die "monoclaw doctor --json timed out after 30s. Check ${home_dir}/logs/agent.log."
  else
    # Extract key details from JSON if possible; fall back to raw output.
    local issues_summary=""
    if command -v python3 >/dev/null 2>&1; then
      issues_summary="$(printf '%s' "${doctor_out}" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    issues = d.get('issues', [])
    print('; '.join(issues[:3]))
except Exception:
    print(sys.stdin.read()[:200])
" 2>/dev/null || true)"
    fi
    if [[ -n "${issues_summary}" ]]; then
      warn_or_die "monoclaw doctor reported issues: ${issues_summary}. Run 'monoclaw provision' to fix."
    else
      warn_or_die "monoclaw doctor --json exited ${doctor_exit}. Run 'monoclaw provision' to fix."
    fi
  fi
}

run_verify_local_inference() {
  local home_dir
  home_dir="$(monoclaw_home)"

  log_step "verify" "Checking optional local inference readiness"
  if lm_studio_app_installed; then
    log_ok "LM Studio app present at $(lm_studio_app_path)"
  else
    log_warn "LM Studio app is missing at $(lm_studio_app_path)"
  fi

  local gemma_dir
  gemma_dir="$(gemma_lmstudio_models_dir)"
  if [[ -f "${gemma_dir}/gemma-4-E4B-it-Q4_K_M.gguf" ]]; then
    log_ok "Gemma 4 E4B chat weights present in LM Studio models directory"
  else
    log_warn "Gemma 4 E4B chat weights missing from ${gemma_dir}"
  fi
  if [[ -f "${gemma_dir}/mmproj-gemma-4-E4B-it-f16.gguf" ]]; then
    log_ok "Gemma 4 E4B vision projector (mmproj) present"
  else
    log_warn "Gemma 4 E4B mmproj missing from ${gemma_dir}"
  fi

  if [[ -f "${home_dir}/.env" ]] \
    && grep -q "LM_BASE_URL=http://127.0.0.1:1234/v1" "${home_dir}/.env" \
    && grep -q "LM_API_KEY=dummy-lm-api-key" "${home_dir}/.env" \
    && grep -q "MONOCLAW_MODEL=local:gemma4:e4b" "${home_dir}/.env" \
    && [[ -f "${home_dir}/config.yaml" ]] \
    && grep -q "provider: lmstudio" "${home_dir}/config.yaml"; then
    log_ok "LM Studio runtime defaults present"
  else
    log_warn "LM Studio runtime defaults are missing; run monoclaw setup to select the provider"
  fi
}

model_pack_manifest_field() {
  local field="$1"
  local python_bin
  python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}")"
  PYTHONDONTWRITEBYTECODE=1 HATCH_MODEL_PACK_ROOT="${HATCH_MODEL_PACK_ROOT}" "${python_bin}" - "${field}" <<'PY'
import json
import os
import sys
from pathlib import Path

field = sys.argv[1]
manifest = Path(os.environ["HATCH_MODEL_PACK_ROOT"]) / "model-pack-manifest.json"
data = json.loads(manifest.read_text(encoding="utf-8"))
model = data.get("model", {})
value = model.get(field, "")
if value:
    print(value)
PY
}

model_pack_artifact_paths() {
  local python_bin
  python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}")"
  PYTHONDONTWRITEBYTECODE=1 HATCH_MODEL_PACK_ROOT="${HATCH_MODEL_PACK_ROOT}" "${python_bin}" <<'PY'
import json
import os
from pathlib import Path

manifest = Path(os.environ["HATCH_MODEL_PACK_ROOT"]) / "model-pack-manifest.json"
data = json.loads(manifest.read_text(encoding="utf-8"))
for artifact in data.get("artifacts", []):
    path = artifact.get("path")
    if path:
        print(path)
PY
}

run_verify_model_pack() {
  log_step "model-pack" "Checking optional Gemma model pack"
  verify_model_pack_manifest "${HATCH_MODEL_PACK_ROOT}" | sed 's/^/  ok: /'
}

run_install_model() {
  local target_dir
  local model_rel
  local model_name
  local source_path
  local target_path
  local tmp_path

  if ! lm_studio_app_installed; then
    die "LM Studio is not installed. Install it from the official .dmg before running install-model."
  fi

  run_verify_model_pack
  target_dir="$(gemma_lmstudio_models_dir)"

  log_step "model-pack" "Installing optional Gemma 4 E4B model into LM Studio"
  log_action mkdir -p "${target_dir}"

  while IFS= read -r model_rel; do
    [[ -n "${model_rel}" ]] || continue
    model_name="$(basename "${model_rel}")"
    source_path="${HATCH_MODEL_PACK_ROOT}/${model_rel}"
    target_path="${target_dir}/${model_name}"
    tmp_path="${target_dir}/.${model_name}.tmp"
    log_action cp "${source_path}" "${tmp_path}"
    log_action mv "${tmp_path}" "${target_path}"
    if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
      printf '  dry-run: staged %s\n' "${target_path}"
    else
      log_ok "Staged ${model_name} at ${target_path}"
    fi
  done < <(model_pack_artifact_paths)

  if [[ "${HATCH_DRY_RUN}" != "true" ]]; then
    log_ok "Gemma 4 E4B model pack installed under ${target_dir}"
    printf '  next: launch LM Studio once; it should auto-discover the bundled GGUF files\n'
  fi
}

run_verify_tools_pack() {
  log_step "tools-pack" "Checking optional Mona secretary tools pack"
  verify_tools_pack_manifest "${HATCH_TOOLS_PACK_ROOT}" "mona-secretary-tools" | sed 's/^/  ok: /'
}

install_tools_pack_plugins() {
  local source_dir="$1"
  local target_dir="$2"

  if [[ ! -d "${source_dir}" ]]; then
    log_warn "No Mona secretary plugins staged at ${source_dir}"
    return
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: install Mona secretary plugins into %s\n' "${target_dir}"
    return
  fi

  mkdir -p "${target_dir}"
  for plugin_path in "${source_dir}"/*; do
    [[ -e "${plugin_path}" ]] || continue
    local plugin_name
    plugin_name="$(basename "${plugin_path}")"
    if [[ -e "${target_dir}/${plugin_name}" ]]; then
      log_warn "Keeping existing plugin ${target_dir}/${plugin_name}"
      continue
    fi
    cp -R "${plugin_path}" "${target_dir}/${plugin_name}"
  done
  log_ok "Mona secretary plugins installed into ${target_dir}"
}

run_install_tools() {
  local home_dir
  local target_dir
  home_dir="$(monoclaw_home)"
  target_dir="${home_dir}/vendor/mona-tools"

  run_verify_tools_pack
  log_step "tools-pack" "Installing optional Mona secretary tools"
  log_action rm -rf "${target_dir}"
  log_action mkdir -p "${home_dir}/vendor"
  log_action cp -R "${HATCH_TOOLS_PACK_ROOT}" "${target_dir}"
  install_tools_pack_plugins "${HATCH_TOOLS_PACK_ROOT}/plugins" "${home_dir}/plugins"
  printf '  manual: review %s before enabling host automation tools\n' "${target_dir}/docs/permissions.md"
  printf '  manual: copy MCP examples from %s only after reviewing path and permission scopes\n' "${target_dir}/config"
  printf '  next: technician provision complete; end user runs: monoclaw onboard\n'
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: Mona secretary tools installed at %s\n' "${target_dir}"
  else
    log_ok "Mona secretary tools installed at ${target_dir}"
  fi
}

run_verify_skill_deps() {
  log_step "skill-deps" "Checking optional skill-deps pack"
  if [[ ! -d "${HATCH_SKILL_DEPS_PACK_ROOT}" ]]; then
    log_warn "Skill dependencies pack not present at ${HATCH_SKILL_DEPS_PACK_ROOT} (Phase 5 scaffolding ships empty by default)"
    return
  fi
  if [[ ! -f "${HATCH_SKILL_DEPS_PACK_ROOT}/tools-pack-manifest.json" ]]; then
    warn_or_die "Skill dependencies pack missing tools-pack-manifest.json at ${HATCH_SKILL_DEPS_PACK_ROOT}"
    return
  fi
  verify_tools_pack_manifest "${HATCH_SKILL_DEPS_PACK_ROOT}" "skill-deps-pack" | sed 's/^/  ok: /'
}

skill_deps_python_specs_present() {
  local scan_root="$1"
  local python_bin
  python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT:-}")" || return 1
  PYTHONDONTWRITEBYTECODE=1 "${python_bin}" - "${scan_root}" <<'PY'
import sys
from pathlib import Path

root = Path(sys.argv[1])
sys.exit(0 if any(root.glob("python/*/package-spec.json")) else 1)
PY
}

install_skill_deps_python_tools() {
  local scan_root="$1"
  local target_dir="$2"
  local home_dir="$3"
  local runtime_python=""
  local python_bin

  if ! skill_deps_python_specs_present "${scan_root}"; then
    return
  fi

  if [[ "${HATCH_DRY_RUN}" != "true" ]]; then
    if ! runtime_python="$(select_runtime_python "${home_dir}")"; then
      die "Python-backed skill dependencies require bundled Python at ${home_dir}/vendor/python/current/bin/python3"
    fi
  fi

  python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT:-}")" || die "Python is required to install Python-backed skill dependencies"
  PYTHONDONTWRITEBYTECODE=1 \
  HATCH_DRY_RUN="${HATCH_DRY_RUN}" \
  HATCH_SKILL_DEPS_SCAN_ROOT="${scan_root}" \
  HATCH_SKILL_DEPS_TARGET_ROOT="${target_dir}" \
  HATCH_SKILL_DEPS_RUNTIME_PYTHON="${runtime_python}" \
    "${python_bin}" <<'PY'
from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

dry_run = os.environ.get("HATCH_DRY_RUN", "true") == "true"
scan_root = Path(os.environ["HATCH_SKILL_DEPS_SCAN_ROOT"])
target_root = Path(os.environ["HATCH_SKILL_DEPS_TARGET_ROOT"])
runtime_python = os.environ.get("HATCH_SKILL_DEPS_RUNTIME_PYTHON", "")

def _version_tuple(value: str) -> tuple[int, int, int] | None:
    if not value:
        return None
    parts = value.split(".")
    try:
        return (
            int(parts[0]),
            int(parts[1]) if len(parts) > 1 else 0,
            int(parts[2]) if len(parts) > 2 else 0,
        )
    except (TypeError, ValueError):
        return None

def ensure_runtime_python_satisfies(min_python: str, tool: str) -> None:
    minimum = _version_tuple(min_python)
    if minimum is None or dry_run:
        return
    raw = subprocess.check_output(
        [
            runtime_python,
            "-c",
            "import sys; print('.'.join(map(str, sys.version_info[:3])))",
        ],
        text=True,
        timeout=15,
    ).strip()
    actual = _version_tuple(raw)
    if actual is None or actual < minimum:
        need = ".".join(str(part) for part in minimum)
        found = ".".join(str(part) for part in actual) if actual else "unknown"
        raise SystemExit(
            f"Python-backed skill dependency {tool} requires bundled Python >= {need}, found {found}"
        )

for spec_path in sorted(scan_root.glob("python/*/package-spec.json")):
    rel_parent = spec_path.parent.relative_to(scan_root)
    spec = json.loads(spec_path.read_text(encoding="utf-8"))
    tool = str(spec.get("tool") or spec_path.parent.name)
    package = str(spec.get("package") or tool)
    version = str(spec.get("version") or "")
    entrypoint = str(spec.get("entrypoint") or tool)
    min_python = str(spec.get("min_python") or "")
    if not version:
        raise SystemExit(f"skill-deps package spec missing version: {spec_path}")
    ensure_runtime_python_satisfies(min_python, tool)

    install_root = target_root / rel_parent
    wheelhouse = install_root / "wheelhouse"
    venv = install_root / "venv"
    shim = target_root / "bin" / tool
    requirement = f"{package}=={version}"

    if dry_run:
        print(f"  dry-run: <runtime-python> -m venv {venv}")
        print(f"  dry-run: {venv / 'bin' / 'python'} -m pip install --no-index --find-links {wheelhouse} {requirement}")
        print(f"  dry-run: write {shim} shim")
        continue

    if not wheelhouse.is_dir():
        raise SystemExit(f"skill-deps wheelhouse missing: {wheelhouse}")
    if not any(wheelhouse.glob("*.whl")):
        raise SystemExit(f"skill-deps wheelhouse is empty: {wheelhouse}")
    if not runtime_python:
        raise SystemExit("runtime Python path is required for Python-backed skill dependencies")

    shutil.rmtree(venv, ignore_errors=True)
    subprocess.check_call([runtime_python, "-m", "venv", str(venv)])
    subprocess.check_call(
        [
            str(venv / "bin" / "python"),
            "-m",
            "pip",
            "install",
            "--no-index",
            "--find-links",
            str(wheelhouse),
            requirement,
        ]
    )

    shim.parent.mkdir(parents=True, exist_ok=True)
    shim.write_text(
        "#!/usr/bin/env bash\n"
        "set -euo pipefail\n"
        "SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n"
        f"exec \"${{SCRIPT_DIR}}/../{rel_parent.as_posix()}/venv/bin/{entrypoint}\" \"$@\"\n",
        encoding="utf-8",
    )
    shim.chmod(0o755)
    print(f"  ok: installed Python-backed skill dependency {tool} into {venv}")
PY
}

run_verify_skill_readiness() {
  local home_dir
  home_dir="$(monoclaw_home)"

  log_step "skill-readiness" "Auditing installed skills against metadata.monoclaw.provisioning"

  local python_bin=""
  if [[ -x "${home_dir}/vendor/runtime/venv/bin/python3" ]]; then
    python_bin="${home_dir}/vendor/runtime/venv/bin/python3"
  elif python_bin="$(hatch_manifest_python "${HATCH_BUNDLE_ROOT}" 2>/dev/null)"; then
    :
  elif command -v python3 >/dev/null 2>&1; then
    python_bin="$(command -v python3)"
  else
    log_warn "No python3 available to parse SKILL.md frontmatter"
    return
  fi

  local exit_code=0
  PYTHONDONTWRITEBYTECODE=1 \
  MONOCLAW_HOME="${home_dir}" \
  HATCH_DRY_RUN="${HATCH_DRY_RUN}" \
  HATCH_SKILL_READINESS_FAIL_ON="${HATCH_SKILL_READINESS_FAIL_ON:-blocked_unknown}" \
    "${python_bin}" - <<'PY' || exit_code=$?
from __future__ import annotations
import os
import re
import sys
from pathlib import Path

HOME = Path(os.environ["MONOCLAW_HOME"])
EXCLUDED = {".git", ".github", ".hub", ".archive"}

POLICIES = {
    "stock_bundle_candidate",
    "provisioned_user_config_required",
    "external_runtime_only",
    "blocked_unknown",
}

LABELS = {
    "stock_bundle_candidate": "Ready",
    "provisioned_user_config_required": "Setup required",
    "external_runtime_only": "External runtime",
    "blocked_unknown": "Unclassified",
}


def extract_frontmatter(text: str) -> str:
    if not text.startswith("---"):
        return ""
    m = re.search(r"\n---\s*(?:\n|$)", text[3:])
    if not m:
        return ""
    return text[3 : m.start() + 3]


def _indent(line: str) -> int:
    return len(line) - len(line.lstrip(" "))


def find_provisioning_block(yaml_text: str) -> list[str] | None:
    """Locate the metadata.monoclaw.provisioning block lines.

    Avoids depending on PyYAML so this gate works under
    ``/usr/bin/python3`` on a freshly imaged Mac (the runtime venv with
    PyYAML may not exist yet at the moment ``verify-skill-readiness``
    is first invoked).
    """
    lines = yaml_text.splitlines()
    i = 0
    n = len(lines)
    while i < n:
        line = lines[i]
        if line.lstrip(" ").startswith("metadata:") and _indent(line) == 0:
            meta_indent = 0
            j = i + 1
            mc_indent = None
            while j < n:
                child = lines[j]
                if not child.strip():
                    j += 1
                    continue
                if _indent(child) <= meta_indent:
                    break
                if child.lstrip(" ").startswith("monoclaw:"):
                    mc_indent = _indent(child)
                    k = j + 1
                    prov_indent = None
                    while k < n:
                        prov_line = lines[k]
                        if not prov_line.strip():
                            k += 1
                            continue
                        if _indent(prov_line) <= mc_indent:
                            break
                        if prov_line.lstrip(" ").startswith("provisioning:"):
                            prov_indent = _indent(prov_line)
                            block_lines = []
                            m = k + 1
                            while m < n:
                                bl = lines[m]
                                if bl.strip() and _indent(bl) <= prov_indent:
                                    break
                                block_lines.append(bl)
                                m += 1
                            return block_lines
                        k += 1
                    return None
                j += 1
            return None
        i += 1
    return None


_BUNDLE_POLICY_RE = re.compile(r"^\s*bundle_policy:\s*([A-Za-z_][A-Za-z0-9_]*)")
_SYS_DEPS_HEADER_RE = re.compile(r"^(\s*)system_dependencies:\s*(.*)$")
_INLINE_LIST_RE = re.compile(r"\[([^\]]*)\]")
_LIST_ITEM_RE = re.compile(r"^\s*-\s+(.*)$")


def policy_from_block(block: list[str] | None) -> str:
    if not block:
        return "blocked_unknown"
    for line in block:
        m = _BUNDLE_POLICY_RE.match(line)
        if m:
            value = m.group(1).strip()
            return value if value in POLICIES else "blocked_unknown"
    return "blocked_unknown"


def _strip_quote(value: str) -> str:
    value = value.strip()
    if value.startswith(("'", '"')) and value.endswith(("'", '"')) and len(value) >= 2:
        return value[1:-1]
    return value


def system_deps_from_block(block: list[str] | None) -> list[str]:
    if not block:
        return []
    out: list[str] = []
    in_list = False
    list_indent = 0
    for line in block:
        header = _SYS_DEPS_HEADER_RE.match(line)
        if header:
            list_indent = len(header.group(1))
            inline = header.group(2).strip()
            inline_match = _INLINE_LIST_RE.match(inline)
            if inline_match:
                for raw in inline_match.group(1).split(","):
                    item = _strip_quote(raw.strip())
                    if item:
                        out.append(item)
                in_list = False
                continue
            in_list = True
            continue
        if in_list:
            if not line.strip():
                continue
            indent = _indent(line)
            if indent <= list_indent:
                in_list = False
                continue
            item_match = _LIST_ITEM_RE.match(line)
            if item_match:
                item = _strip_quote(item_match.group(1).strip())
                if item:
                    out.append(item)
    return out


def policy_for(yaml_text: str) -> str:
    return policy_from_block(find_provisioning_block(yaml_text))


def system_deps_for(yaml_text: str) -> list[str]:
    return system_deps_from_block(find_provisioning_block(yaml_text))


def find_dep_binary(name: str) -> Path | None:
    candidates = [
        HOME / "vendor" / "skill-deps" / "bin" / name,
        HOME / "vendor" / "mona-tools" / "bin" / name,
    ]
    for path in candidates:
        if path.is_file() and os.access(path, os.X_OK):
            return path
    return None


def walk_skills(root: Path):
    if not root.is_dir():
        return
    for skill_md in sorted(root.rglob("SKILL.md")):
        rel = skill_md.relative_to(root)
        if any(p in EXCLUDED or p.startswith(".") for p in rel.parts[:-1]):
            continue
        yield skill_md


totals = {p: 0 for p in POLICIES}
missing_deps: list[tuple[str, str]] = []
skill_count = 0

for tree in (HOME / "skills",):
    for skill_md in walk_skills(tree):
        skill_count += 1
        try:
            text = skill_md.read_text(encoding="utf-8")
        except OSError:
            totals["blocked_unknown"] += 1
            continue
        yaml_text = extract_frontmatter(text)
        policy = policy_for(yaml_text)
        totals[policy] += 1
        for dep in system_deps_for(yaml_text):
            if find_dep_binary(dep) is None:
                missing_deps.append((str(skill_md), dep))

print(f"  skills checked: {skill_count}")
for policy in (
    "stock_bundle_candidate",
    "provisioned_user_config_required",
    "external_runtime_only",
    "blocked_unknown",
):
    print(f"  {LABELS[policy]:<22} {totals[policy]:>3}  ({policy})")

fail_on = os.environ.get("HATCH_SKILL_READINESS_FAIL_ON", "blocked_unknown").strip()
fail = False
if fail_on:
    threshold_count = totals.get(fail_on, 0)
    if threshold_count > 0:
        if os.environ.get("HATCH_DRY_RUN", "true") == "true":
            print(f"  warn: {threshold_count} skill(s) at threshold '{fail_on}'", file=sys.stderr)
        else:
            print(f"  fail: {threshold_count} skill(s) at threshold '{fail_on}'", file=sys.stderr)
            fail = True

if missing_deps:
    print(
        f"  note: {len(missing_deps)} skill(s) declare system_dependencies that are not installed under "
        "~/.monoclaw/vendor/skill-deps/bin or ~/.monoclaw/vendor/mona-tools/bin"
    )
    for path, dep in missing_deps[:5]:
        print(f"    - {dep!r} required by {path}")
    if len(missing_deps) > 5:
        print(f"    ... ({len(missing_deps) - 5} more)")

sys.exit(1 if fail else 0)
PY

  if [[ ${exit_code} -ne 0 ]]; then
    if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
      log_warn "skill-readiness gate would fail (dry-run)"
    else
      die "skill-readiness gate failed"
    fi
  else
    log_ok "skill readiness audit passed"
  fi

  # ── Binary smoke probes for installed skill-deps ──────────────────────────
  # Verify that each installed skill-dep binary actually runs, not just that
  # the file is present with the right SHA. A binary that exists but fails its
  # status/health command (e.g. remindctl before macOS Reminders authorization)
  # needs to be surfaced here so the technician can authorize it before handing
  # off to the customer.
  local skill_deps_bin="${home_dir}/vendor/skill-deps/bin"
  if [[ -d "${skill_deps_bin}" ]]; then
    log_step "skill-readiness" "Probing installed skill-dep binaries"
    # Format: "<binary_name>:<space-separated argv after the binary>".
    # ``imsg`` does NOT have a ``health`` subcommand (the previous spelling
    # used here was wrong and surfaced as a misleading warning on every
    # fresh install). The canonical readiness probe for ``imsg`` is
    # ``chats --limit 1 --json`` — the same command the runtime's
    # ``SkillDepsModule`` activation flow uses and the same command the
    # Phase-3 ``imsg`` sub-wizard exercises in ``verify()``.
    local _probe_spec _probe_binary _probe_args_str _probe_out _probe_exit
    local -a _probe_argv
    for _probe_spec in \
        "remindctl:status" \
        "imsg:chats --limit 1 --json" \
        "memo:--version" \
        "himalaya:--version"; do
      _probe_binary="${skill_deps_bin}/${_probe_spec%%:*}"
      _probe_args_str="${_probe_spec#*:}"
      [[ -x "${_probe_binary}" ]] || continue
      # shellcheck disable=SC2206
      read -ra _probe_argv <<< "${_probe_args_str}"
      _probe_out=""
      _probe_exit=0
      _probe_out="$(hatch_run_with_timeout 10 "${_probe_binary}" "${_probe_argv[@]}" 2>&1)" || _probe_exit=$?
      if [[ ${_probe_exit} -eq 0 ]]; then
        log_ok "${_probe_spec%%:*}: ${_probe_args_str} → OK"
      else
        log_warn "${_probe_spec%%:*}: '${_probe_args_str}' exited ${_probe_exit} — binary may need authorization via 'monoclaw provision'"
        if [[ -n "${_probe_out}" ]]; then
          printf '    %s\n' "${_probe_out}" | head -5
        fi
      fi
    done
  fi
}

run_install_skill_deps() {
  local home_dir
  local target_dir
  home_dir="$(monoclaw_home)"
  target_dir="${home_dir}/vendor/skill-deps"

  if [[ ! -d "${HATCH_SKILL_DEPS_PACK_ROOT}" ]]; then
    log_warn "No skill-deps pack at ${HATCH_SKILL_DEPS_PACK_ROOT}; nothing to install (default for current bundles)"
    return
  fi

  run_verify_skill_deps
  log_step "skill-deps" "Installing optional skill dependencies"
  log_action rm -rf "${target_dir}"
  log_action mkdir -p "${home_dir}/vendor"
  log_action cp -R "${HATCH_SKILL_DEPS_PACK_ROOT}" "${target_dir}"
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    install_skill_deps_python_tools "${HATCH_SKILL_DEPS_PACK_ROOT}" "${target_dir}" "${home_dir}"
  else
    install_skill_deps_python_tools "${target_dir}" "${target_dir}" "${home_dir}"
  fi
  install_class_a_brew_formulas
  run_install_core_deps
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: skill dependencies installed at %s\n' "${target_dir}"
  else
    log_ok "skill dependencies installed at ${target_dir}"
  fi
}

# ---------------------------------------------------------------------------
# Class-A brew formula installation
#
# Per ``plans/provision-sub-wizards-and-homebrew-pivot.md`` (and the new
# section in ``CLAUDE.md``), each Class-A skill-dep tool is **brew-first when
# online, bundle-fallback offline**. The bundle copy in
# ``run_install_skill_deps`` runs unconditionally so air-gapped installs keep
# working — this helper layers an opportunistic ``brew install`` on top so
# technicians get the idiomatic brew binaries on their PATH and can upgrade
# them with ``brew upgrade`` instead of re-bundling.
#
# Skipped when:
#   * ``HATCH_INSTALL_OFFLINE=1`` is set (explicit air-gap mode).
#   * ``HATCH_INSTALL_BREW_FORMULAS=0`` is set (technician opt-out).
#   * ``brew`` is not on PATH (target Mac is bundle-only).
#
# Class-B tools (today: ``imsg``) have no brew formula and are intentionally
# absent from the list — the bundle copy is their only install path.
# ---------------------------------------------------------------------------
install_class_a_brew_formulas() {
  if [[ "${HATCH_INSTALL_OFFLINE:-0}" == "1" ]]; then
    log_step "skill-deps:brew" "HATCH_INSTALL_OFFLINE=1; skipping brew install (bundle-only)"
    return
  fi
  if [[ "${HATCH_INSTALL_BREW_FORMULAS:-1}" == "0" ]]; then
    log_step "skill-deps:brew" "HATCH_INSTALL_BREW_FORMULAS=0; skipping brew install"
    return
  fi
  if ! have_command brew; then
    log_step "skill-deps:brew" "brew not on PATH; skipping brew install (using bundled binaries only)"
    return
  fi

  log_step "skill-deps:brew" "Installing Class-A brew formulas (idempotent)"
  # Each entry is "<tool>|<brew_spec>". The tool name is informational
  # (matches the bundled binary basename); the spec is what we pass to
  # ``brew install``. Memo MUST use the antoniorodr tap because the bare
  # name ``memo`` resolves to a deprecated cask in homebrew/core.
  local entry tool spec
  for entry in \
      "himalaya|himalaya" \
      "remindctl|steipete/tap/remindctl" \
      "memo|antoniorodr/memo/memo"; do
    tool="${entry%%|*}"
    spec="${entry#*|}"
    if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
      printf '  dry-run: brew install --quiet %s   # (%s, idempotent)\n' "${spec}" "${tool}"
      continue
    fi
    if brew install --quiet "${spec}"; then
      log_ok "skill-deps:brew ${tool}: '${spec}' installed (or already up to date)"
    else
      log_warn "skill-deps:brew ${tool}: 'brew install ${spec}' failed; falling back to bundled binary"
    fi
  done
}

# ---------------------------------------------------------------------------
# Class-C / Class-D core dependencies
#
# Per ``plans/provision-sub-wizards-and-homebrew-pivot.md`` §4.5–4.8 and
# §5.2: language runtimes (``node``/``npm``, ``uv``) and system libraries
# (``opus``, ``ffmpeg``) are brew-only on macOS in this iteration. The
# runtime venv stays bundle-first per ``CLAUDE.md`` — this helper does NOT
# touch Python in any form.
#
# Skipped under the same gates as ``install_class_a_brew_formulas``:
#   * ``HATCH_INSTALL_OFFLINE=1`` — air-gap mode.
#   * ``HATCH_INSTALL_CORE_DEPS=0`` — technician opt-out specific to this
#     helper. Distinct from ``HATCH_INSTALL_BREW_FORMULAS=0`` so a
#     technician can keep core deps while opting out of the Class-A
#     formulas, or vice versa.
#   * brew missing from PATH.
#
# This runs only when ``HATCH_INSTALL_CORE_DEPS_ON_INSTALL`` is set (default:
# disabled) to preserve the existing top-level install behaviour. When
# enabled, the runtime sub-wizards still re-detect and can install on
# demand during ``monoclaw provision`` — Hatch is the first opportunity,
# not the only one.
# ---------------------------------------------------------------------------
run_install_core_deps() {
  if [[ "${HATCH_INSTALL_OFFLINE:-0}" == "1" ]]; then
    log_step "core-deps" "HATCH_INSTALL_OFFLINE=1; skipping (monoclaw provision will detect and prompt later)"
    return
  fi
  if [[ "${HATCH_INSTALL_CORE_DEPS:-1}" == "0" ]]; then
    log_step "core-deps" "HATCH_INSTALL_CORE_DEPS=0; skipping"
    return
  fi
  if ! have_command brew; then
    log_step "core-deps" "brew not on PATH; skipping (install via monoclaw provision after Homebrew is set up)"
    return
  fi

  log_step "core-deps" "Installing Class-C language runtimes and Class-D system libraries (idempotent)"
  # Format: "<spec>|<friendly description>".
  # ``node`` bundles ``npm``; we don't list it separately. ``opus`` is a
  # system library — brew install lays down ``libopus.dylib`` under the
  # active prefix, which the runtime's ``opus`` sub-wizard then verifies.
  # ``ripgrep`` is in the core-deps list (added 2026-05) because every
  # MonoClaw file-search code path falls back to slow grep when ``rg`` is
  # missing; ``scripts/install.sh`` already installs it on the curl-bash
  # path, but the Hatch path used to silently skip it and surface as a
  # doctor warning every fresh install.
  local entry spec description
  for entry in \
      "node|Node.js LTS (+npm)" \
      "uv|Astral uv (Python env manager)" \
      "opus|Opus codec (Discord voice)" \
      "ffmpeg|ffmpeg (TTS playback, voice mode)" \
      "ripgrep|ripgrep (fast file search; rg)"; do
    spec="${entry%%|*}"
    description="${entry#*|}"
    if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
      printf '  dry-run: brew install --quiet %s   # (%s, idempotent)\n' "${spec}" "${description}"
      continue
    fi
    if brew install --quiet "${spec}"; then
      log_ok "core-deps ${spec}: installed (or already up to date) — ${description}"
    else
      log_warn "core-deps ${spec}: 'brew install ${spec}' failed; monoclaw provision will surface this later"
    fi
  done
}

# ---------------------------------------------------------------------------
# agent-browser provisioning (online-first, bundle-fallback)
#
# agent-browser is the npm package the runtime drives for headless
# browser automation. Doctor warns when it is missing, and pre-2026-05
# Hatch never installed it on the customer Mac — an entire class of
# tools silently fell back to "no browser" mode after a clean install.
#
# Online-first / bundle-fallback mirrors the Class-A brew formula
# pattern (himalaya / remindctl / memo): try the canonical source
# (``npm install -g agent-browser@<pin>``) when online, and fall back
# to copying the bundled ``node_modules`` into
# ``~/.monoclaw/vendor/browser/`` when offline. The doctor's
# ``_locate_agent_browser`` helper sees both locations.
#
# Skipped under:
#
#   * ``HATCH_INSTALL_OFFLINE=1``           — air-gapped install (bundle-only)
#   * ``HATCH_INSTALL_AGENT_BROWSER=0``     — technician opt-out (mirror of
#                                              ``HATCH_INSTALL_BREW_FORMULAS=0``)
#
# When online, ``npm`` is required (we install it via core-deps just
# above this call). If the npm step fails for any reason we still try
# the bundle copy so the customer is never left worse than offline.
# ---------------------------------------------------------------------------

# Pin the agent-browser version. Keep in sync with ``monoclaw-runtime/package.json``
# (``"agent-browser": "^0.26.0"``). Hatch owns this pin directly so a
# bundle build is reproducible without resolving a semver range against
# the npm registry at install time.
HATCH_AGENT_BROWSER_VERSION="${HATCH_AGENT_BROWSER_VERSION:-0.26.0}"

install_agent_browser_via_npm() {
  # Returns 0 on success (installed or already present), 1 on failure.
  local home_dir="$1"

  if [[ "${HATCH_INSTALL_OFFLINE:-0}" == "1" ]]; then
    return 1
  fi
  if ! have_command npm; then
    log_warn "agent-browser: npm not on PATH; cannot install via npm (core-deps may have failed)"
    return 1
  fi

  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    printf '  dry-run: npm install -g agent-browser@%s\n' "${HATCH_AGENT_BROWSER_VERSION}"
    return 0
  fi

  # ``npm install -g`` is the canonical Hatch path: the binary lands on
  # PATH (npm prefix) and ``_locate_agent_browser`` finds it via
  # ``shutil.which``. We capture stderr so a network-blocked install
  # surfaces a useful diagnostic before we fall back to the bundle.
  local npm_log
  npm_log="$(mktemp)"
  if npm install --silent -g "agent-browser@${HATCH_AGENT_BROWSER_VERSION}" 2>"${npm_log}"; then
    rm -f "${npm_log}"
    log_ok "agent-browser ${HATCH_AGENT_BROWSER_VERSION}: installed via npm -g"
    return 0
  fi

  log_warn "agent-browser: 'npm install -g agent-browser@${HATCH_AGENT_BROWSER_VERSION}' failed"
  if [[ -s "${npm_log}" ]]; then
    sed 's/^/    npm: /' "${npm_log}" | head -5
  fi
  rm -f "${npm_log}"
  return 1
}

install_agent_browser_via_bundle() {
  # Returns 0 on success (bundle copied or already in place), 1 if no
  # bundled copy is available (caller decides whether that is fatal).
  local home_dir="$1"
  local source_dir="${HATCH_BUNDLE_ROOT}/vendor/browser"
  local target_dir="${home_dir}/vendor/browser"

  # The bundle source path. ``copy_optional_vendor_asset "browser"``
  # already runs during ``stage_bundle`` (build.sh:446) and stages
  # ``bundle-inputs/vendor/browser/`` to ``dist/vendor/browser/``. At
  # install time ``install_runtime_assets`` ALSO copies that subtree to
  # ``~/.monoclaw/vendor/browser/`` — so on a real install the bundle
  # is already present. We re-verify here defensively.
  if [[ "${HATCH_DRY_RUN}" == "true" ]]; then
    if [[ -d "${source_dir}/node_modules/agent-browser" ]]; then
      printf '  dry-run: agent-browser bundle present at %s — install_runtime_assets stages it to %s\n' \
        "${source_dir}" "${target_dir}"
      return 0
    fi
    printf '  dry-run: no agent-browser bundle at %s; bundle-fallback unavailable\n' "${source_dir}"
    return 1
  fi

  if [[ -d "${target_dir}/node_modules/agent-browser" ]]; then
    log_ok "agent-browser: bundle copy in place at ${target_dir}/node_modules/agent-browser"
    return 0
  fi

  if [[ -d "${source_dir}/node_modules/agent-browser" ]]; then
    # install_runtime_assets normally handles this, but if a technician
    # rebuilds or runs a partial install we copy here defensively. ``cp -R``
    # is idempotent: if the dest exists we removed it above.
    mkdir -p "${target_dir}"
    if cp -R "${source_dir}/node_modules" "${target_dir}/node_modules"; then
      log_ok "agent-browser: bundle staged to ${target_dir}/node_modules/agent-browser"
      return 0
    fi
    log_warn "agent-browser: failed to copy bundle from ${source_dir} to ${target_dir}"
    return 1
  fi

  log_warn "agent-browser: no bundled copy available at ${source_dir} (bundle was built without browser assets)"
  return 1
}

run_install_agent_browser() {
  if [[ "${HATCH_INSTALL_AGENT_BROWSER:-1}" == "0" ]]; then
    log_step "agent-browser" "HATCH_INSTALL_AGENT_BROWSER=0; skipping"
    return
  fi

  local home_dir
  home_dir="$(monoclaw_home)"

  log_step "agent-browser" "Installing agent-browser (npm-first, bundle-fallback)"

  # Try the online path first. Bundle fallback runs when:
  #   * we are explicitly offline (HATCH_INSTALL_OFFLINE=1), OR
  #   * the npm install failed for any reason.
  if [[ "${HATCH_INSTALL_OFFLINE:-0}" == "1" ]]; then
    log_step "agent-browser" "HATCH_INSTALL_OFFLINE=1; skipping npm and using bundle"
    install_agent_browser_via_bundle "${home_dir}" || \
      log_warn "agent-browser: not installed (offline + no bundle); browser tools will be unavailable until 'npm install -g agent-browser' runs online"
    return
  fi

  if install_agent_browser_via_npm "${home_dir}"; then
    return
  fi

  log_step "agent-browser" "npm path failed; falling back to bundled copy"
  if ! install_agent_browser_via_bundle "${home_dir}"; then
    log_warn "agent-browser: neither npm nor bundle install succeeded; browser tools will be unavailable"
    log_warn "agent-browser: retry online with 'npm install -g agent-browser@${HATCH_AGENT_BROWSER_VERSION} && agent-browser install'"
  fi
}

run_doctor() {
  run_preflight
  run_verify
  run_verify_local_inference
  run_verify_skill_readiness
  log_step "doctor" "Hatch doctor complete"
}

case "${COMMAND}" in
  preflight)
    run_preflight
    ;;
  prepare-bundle)
    run_prepare_bundle
    ;;
  cleanup-existing)
    cleanup_existing_runtime
    ;;
  install)
    run_install
    ;;
  verify)
    run_verify
    ;;
  verify-local-inference)
    run_verify_local_inference
    ;;
  verify-model-pack)
    run_verify_model_pack
    ;;
  install-model)
    run_install_model
    ;;
  verify-tools-pack)
    run_verify_tools_pack
    ;;
  install-tools)
    run_install_tools
    ;;
  verify-skill-deps)
    run_verify_skill_deps
    ;;
  install-skill-deps)
    run_install_skill_deps
    ;;
  install-core-deps)
    run_install_core_deps
    ;;
  install-agent-browser)
    run_install_agent_browser
    ;;
  verify-skill-readiness)
    run_verify_skill_readiness
    ;;
  doctor)
    run_doctor
    ;;
esac
